# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend (email)
RESEND_API_KEY=re_your_key
RESEND_FROM_EMAIL=noreply@yourdomain.com

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
N8N_WEBHOOK_SECRET=replace-with-a-long-random-secret
CRON_SECRET=replace-with-a-long-random-secret
NEWS_RSS_URL=https://www.artificialintelligence-news.com/feed/
NEWS_SOURCE_NAME=AI News
XAI_API_KEY=replace-with-your-xai-api-key
ANTHROPIC_API_KEY=sk-ant-your-key-here
GROK_IMAGE_MODEL=grok-2-image
BLOG_AUTOMATION_AUTHOR_ID=

# Tool discovery pipeline (scripts/discover-and-enrich.mjs)
# Get token: https://www.producthunt.com/v2/oauth/applications
# Create an app → client_credentials grant → paste the access token here
# Without this the script falls back to scraping theresanaiforthat.com
PRODUCT_HUNT_ACCESS_TOKEN=
